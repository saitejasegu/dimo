{
  "name": "dimo-expenses-ui",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/write-version.mjs && next build",
    "start": "npx --yes serve out",
    "test": "npm run test:unit && npm run build",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern design --ignore-pattern ios --ignore-pattern release --ignore-pattern electron",
    "cap:sync": "npm run build && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "ios": "npm run cap:sync && npx cap open ios",
    "electron:dev": "concurrently -k -n next,electron -c cyan,magenta \"next dev\" \"wait-on http://127.0.0.1:3000 && ELECTRON_DEV=1 electron .\"",
    "electron:preview": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@convex-dev/workos": "^0.0.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@workos-inc/authkit-react": "^0.16.1",
    "convex": "^1.42.1",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "electron-serve": "^2.1.1",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.54",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10",
    "wait-on": "^8.0.3"
  },
  "type": "module"
}
