# Copy to .env.local for local web / Capacitor builds.
# These NEXT_PUBLIC_* values are embedded at `next build` time.

# Convex deployment URL (Dashboard → Settings → URL)
NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# WorkOS AuthKit public client (Dashboard → Applications)
NEXT_PUBLIC_WORKOS_CLIENT_ID=client_...

# Browser / Capacitor OAuth redirect (must be allowed in WorkOS)
# Local web:
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Capacitor production builds typically use your hosted callback, e.g.:
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://dimo-silk.vercel.app/callback

# Native Swift app (ios-native) does NOT read this file.
# Configure ConvexURL / WorkOSClientID in ios-native/Config/Shared.xcconfig
# and register dimo://callback in the WorkOS dashboard.
