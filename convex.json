{
  "$schema": "./node_modules/convex/schemas/convex.schema.json",
  "functions": "convex/",
  "authKit": {
    "dev": {
      "configure": {
        "redirectUris": [
          "http://localhost:3000/callback",
          "https://saitejas-macbook-pro.tail54df4a.ts.net/callback",
          "https://saitejas-macbook-pro.tail54df4a.ts.net:3001/callback",
          "https://saitejas-macbook-pro.tail54df4a.ts.net:3002/callback",
          "dimo://callback"
        ],
        "appHomepageUrl": "http://localhost:3000",
        "corsOrigins": [
          "http://localhost:3000",
          "https://saitejas-macbook-pro.tail54df4a.ts.net",
          "https://saitejas-macbook-pro.tail54df4a.ts.net:3001",
          "https://saitejas-macbook-pro.tail54df4a.ts.net:3002"
        ]
      },
      "localEnvVars": {
        "NEXT_PUBLIC_WORKOS_CLIENT_ID": "${authEnv.WORKOS_CLIENT_ID}"
      }
    },
    "preview": {
      "configure": {
        "redirectUris": ["https://${buildEnv.VERCEL_BRANCH_URL}/callback"],
        "appHomepageUrl": "https://${buildEnv.VERCEL_BRANCH_URL}",
        "corsOrigins": ["https://${buildEnv.VERCEL_BRANCH_URL}"]
      }
    },
    "prod": {
      "environmentType": "production",
      "configure": {
        "redirectUris": [
          "https://dimo-silk.vercel.app/callback",
          "dimo://callback"
        ],
        "appHomepageUrl": "https://dimo-silk.vercel.app",
        "corsOrigins": ["https://dimo-silk.vercel.app"]
      }
    }
  }
}
